#!/usr/bin/env python3
"""
Automated Linehaul truck planning with CVRP-like constraints for 2 SOC and multiple Hubs.

Key features implemented from business rules:
- Dual-flow on each used route (First-mile Hub->SOC and Last-mile SOC->Hub).
- Capacity constraints per truck type (1T9, 5T by default).
- Max 3 hubs served per vehicle route.
- Province lock per vehicle (a route cannot mix provinces).
- Optional one-SOC-only mode (default), with optional two-SOC mode.
- Empty-run penalty: if one direction is empty, charge 50% of that leg's cost.

Input data (Excel):
- Sheet `Distance_Matrix_Km`: square matrix [Node x Node] in km.
- Sheet `Time_Matrix_Mins`: square matrix [Node x Node] in minutes.
- Sheet `Node_Metadata`: node info including SOC/Hub, province, FM/LM demand.

Example:
python linehaul_truck_planner.py \
  --excel "D:/.../SPX Case Study_Routing_Matrix_81_Nodes.xlsx" \
  --output ./output \
  --allow-two-soc false
"""

from __future__ import annotations

import argparse
import json
import math
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, Iterable, List, Tuple

import pandas as pd
import pulp


@dataclass(frozen=True)
class TruckType:
    name: str
    capacity_orders: int
    fixed_cost_vnd: float
    var_cost_vnd_per_km: float


DEFAULT_TRUCK_TYPES: Dict[str, TruckType] = {
    "1T9": TruckType(
        name="1T9",
        capacity_orders=1800,
        fixed_cost_vnd=650_000,
        var_cost_vnd_per_km=4_512,
    ),
    "5T": TruckType(
        name="5T",
        capacity_orders=4000,
        fixed_cost_vnd=750_000,
        var_cost_vnd_per_km=6_607,
    ),
}

REQUIRED_METADATA_COLS = {
    "Node",
    "NodeType",  # SOC or HUB
    "Province",
    "FirstMile_Orders",
    "LastMile_Orders",
}


def _normalize_matrix(df: pd.DataFrame) -> pd.DataFrame:
    """
    Normalize matrix so index/columns are both node names.

    Supports formats:
    - First column is node label and remaining columns are destinations.
    - Index already node labels.
    """
    out = df.copy()
    first_col = str(out.columns[0])
    if first_col.lower() in {"node", "nodes", "origin", "from"}:
        out = out.set_index(out.columns[0])
    if out.index.name is None:
        out.index.name = "Node"
    out.columns = [str(c).strip() for c in out.columns]
    out.index = out.index.map(lambda x: str(x).strip())

    if set(out.index) != set(out.columns):
        missing_cols = sorted(set(out.index) - set(out.columns))
        missing_rows = sorted(set(out.columns) - set(out.index))
        raise ValueError(
            "Distance/Time matrix must be square with matching row/column nodes. "
            f"Missing columns for rows: {missing_cols[:5]}, missing rows for cols: {missing_rows[:5]}"
        )

    out = out.loc[out.index, out.index]
    return out


def load_inputs(excel_path: Path) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    distance_raw = pd.read_excel(excel_path, sheet_name="Distance_Matrix_Km")
    time_raw = pd.read_excel(excel_path, sheet_name="Time_Matrix_Mins")
    metadata = pd.read_excel(excel_path, sheet_name="Node_Metadata")

    distance = _normalize_matrix(distance_raw)
    time_mins = _normalize_matrix(time_raw)

    metadata.columns = [str(c).strip() for c in metadata.columns]
    missing = REQUIRED_METADATA_COLS - set(metadata.columns)
    if missing:
        raise ValueError(
            "Missing required columns in Node_Metadata sheet: "
            + ", ".join(sorted(missing))
        )

    metadata = metadata[list(REQUIRED_METADATA_COLS)].copy()
    metadata["Node"] = metadata["Node"].astype(str).str.strip()
    metadata["NodeType"] = metadata["NodeType"].astype(str).str.upper().str.strip()
    metadata["Province"] = metadata["Province"].astype(str).str.strip()
    metadata["FirstMile_Orders"] = metadata["FirstMile_Orders"].fillna(0).astype(float)
    metadata["LastMile_Orders"] = metadata["LastMile_Orders"].fillna(0).astype(float)

    node_set = set(distance.index)
    md_set = set(metadata["Node"])
    if node_set != md_set:
        only_matrix = sorted(node_set - md_set)
        only_md = sorted(md_set - node_set)
        raise ValueError(
            "Node mismatch between matrices and metadata. "
            f"Only in matrix: {only_matrix[:5]}, only in metadata: {only_md[:5]}"
        )

    return distance, time_mins, metadata


def _safe_bool(v: str) -> bool:
    return str(v).strip().lower() in {"1", "true", "yes", "y"}


def solve_province_assignment(
    province: str,
    hubs_df: pd.DataFrame,
    soc_df: pd.DataFrame,
    distance: pd.DataFrame,
    truck_types: Dict[str, TruckType],
    max_hubs_per_trip: int,
    allow_two_soc: bool,
) -> pd.DataFrame:
    """
    MILP assignment model for one province.

    Decision x[h, s, t] = integer #trips by truck type t from SOC s serving Hub h (dual-flow).

    Cost per trip approximated by a SOC->Hub->SOC loop:
    - Base roundtrip distance cost = 2 * d(s,h) * var_cost.
    - Empty penalty applied if one flow is zero at this hub (FM or LM) => +50% one-way cost.
      Implemented as extra 0.5 * d(s,h) * var_cost when min(FM, LM) == 0.

    Objective: fixed cost + variable cost.
    Fixed cost charged per trip (proxy for vehicle-day under daily planning horizon).
    """
    hubs = hubs_df["Node"].tolist()
    socs = soc_df["Node"].tolist()

    model = pulp.LpProblem(f"Linehaul_{province}", pulp.LpMinimize)

    x = {}
    for h in hubs:
        for s in socs:
            for t_name in truck_types:
                x[(h, s, t_name)] = pulp.LpVariable(
                    f"x__{h}__{s}__{t_name}", lowBound=0, cat="Integer"
                )

    # Objective
    cost_terms = []
    for h in hubs:
        fm = float(hubs_df.loc[hubs_df["Node"] == h, "FirstMile_Orders"].iloc[0])
        lm = float(hubs_df.loc[hubs_df["Node"] == h, "LastMile_Orders"].iloc[0])
        empty_penalty_factor = 0.5 if (fm == 0 or lm == 0) else 0.0

        for s in socs:
            d = float(distance.loc[s, h])
            for t_name, tt in truck_types.items():
                per_trip_cost = (
                    tt.fixed_cost_vnd
                    + (2.0 + empty_penalty_factor) * d * tt.var_cost_vnd_per_km
                )
                cost_terms.append(per_trip_cost * x[(h, s, t_name)])

    model += pulp.lpSum(cost_terms)

    # Demand satisfaction (both directions must be carried)
    for h in hubs:
        fm = float(hubs_df.loc[hubs_df["Node"] == h, "FirstMile_Orders"].iloc[0])
        lm = float(hubs_df.loc[hubs_df["Node"] == h, "LastMile_Orders"].iloc[0])
        need = max(fm, lm)

        model += (
            pulp.lpSum(
                truck_types[t_name].capacity_orders * x[(h, s, t_name)]
                for s in socs
                for t_name in truck_types
            )
            >= need,
            f"demand_capacity__{h}",
        )

    # Max hubs per trip is modeled by limiting trips count to ceil(hubs/max_hubs) lower bound,
    # and post-processed route packing to <=3 hubs/truck route.
    # Here we ensure at least enough trip slots for hub count.
    min_trips_for_hub_limit = math.ceil(len(hubs) / max_hubs_per_trip)
    model += (
        pulp.lpSum(x.values()) >= min_trips_for_hub_limit,
        "min_trips_for_hub_limit",
    )

    if not allow_two_soc:
        # One SOC only in a province: select one SOC and force all assignments to it.
        y = {
            s: pulp.LpVariable(f"use_soc__{s}", lowBound=0, upBound=1, cat="Binary")
            for s in socs
        }
        model += pulp.lpSum(y[s] for s in socs) == 1, "one_soc_only"
        M = 10_000
        for h in hubs:
            for s in socs:
                model += (
                    pulp.lpSum(x[(h, s, t)] for t in truck_types) <= M * y[s],
                    f"soc_link__{h}__{s}",
                )

    solver = pulp.PULP_CBC_CMD(msg=False)
    status = model.solve(solver)
    if pulp.LpStatus[status] not in {"Optimal", "Feasible"}:
        raise RuntimeError(
            f"No feasible solution for province {province}. Solver status: {pulp.LpStatus[status]}"
        )

    rows = []
    for (h, s, t), var in x.items():
        trips = int(round(var.value() or 0))
        if trips <= 0:
            continue
        for _ in range(trips):
            rows.append(
                {
                    "Province": province,
                    "SOC": s,
                    "Hub": h,
                    "TruckType": t,
                    "CapacityOrders": truck_types[t].capacity_orders,
                    "FirstMile_Orders": float(
                        hubs_df.loc[hubs_df["Node"] == h, "FirstMile_Orders"].iloc[0]
                    ),
                    "LastMile_Orders": float(
                        hubs_df.loc[hubs_df["Node"] == h, "LastMile_Orders"].iloc[0]
                    ),
                    "Distance_SOC_Hub_Km": float(distance.loc[s, h]),
                    "Distance_Hub_SOC_Km": float(distance.loc[h, s]),
                }
            )

    return pd.DataFrame(rows)


def pack_to_routes(assignments: pd.DataFrame, max_hubs_per_trip: int) -> pd.DataFrame:
    """Pack assignment rows into route IDs with at most `max_hubs_per_trip` hubs per route."""
    if assignments.empty:
        return assignments

    out_frames = []
    route_counter = 1
    group_cols = ["Province", "SOC", "TruckType"]
    for _, g in assignments.groupby(group_cols, sort=False):
        g = g.sort_values("Hub").copy()
        n = len(g)
        chunk_id = [i // max_hubs_per_trip for i in range(n)]
        g["RouteID"] = [f"R{route_counter + c:05d}" for c in chunk_id]
        route_counter += max(chunk_id) + 1
        out_frames.append(g)

    return pd.concat(out_frames, ignore_index=True)


def compute_costs(route_df: pd.DataFrame, truck_types: Dict[str, TruckType]) -> pd.DataFrame:
    """Compute per-route costs with empty-leg penalty rule."""
    if route_df.empty:
        return route_df

    records = []
    for rid, g in route_df.groupby("RouteID"):
        province = g["Province"].iloc[0]
        soc = g["SOC"].iloc[0]
        t = g["TruckType"].iloc[0]
        tt = truck_types[t]

        fm_total = float(g["FirstMile_Orders"].sum())
        lm_total = float(g["LastMile_Orders"].sum())
        # Approximate route distance by summing SOC<->Hub loops per hub in this packed route.
        # If user has full OD route construction later, can replace by exact arc sequencing.
        total_km = float((g["Distance_SOC_Hub_Km"] + g["Distance_Hub_SOC_Km"]).sum())

        empty_penalty_vnd = 0.0
        if fm_total == 0 or lm_total == 0:
            empty_penalty_vnd = 0.5 * total_km * tt.var_cost_vnd_per_km

        variable_cost = total_km * tt.var_cost_vnd_per_km
        total_cost = tt.fixed_cost_vnd + variable_cost + empty_penalty_vnd

        records.append(
            {
                "RouteID": rid,
                "Province": province,
                "SOC": soc,
                "TruckType": t,
                "NumHubs": int(g["Hub"].nunique()),
                "Hubs": " -> ".join(g["Hub"].tolist()),
                "FirstMile_Orders_Total": fm_total,
                "LastMile_Orders_Total": lm_total,
                "TotalDistance_Km_Approx": total_km,
                "FixedCost_VND": tt.fixed_cost_vnd,
                "VariableCost_VND": variable_cost,
                "EmptyRunPenalty_VND": empty_penalty_vnd,
                "TotalCost_VND": total_cost,
            }
        )

    return pd.DataFrame(records).sort_values("TotalCost_VND", ascending=False)


def validate_business_rules(routes: pd.DataFrame, metadata: pd.DataFrame, max_hubs: int) -> List[str]:
    errs: List[str] = []
    if routes.empty:
        return ["No routes generated."]

    province_map = metadata.set_index("Node")["Province"].to_dict()
    for rid, g in routes.groupby("RouteID"):
        hubs = g["Hub"].unique().tolist()
        if len(hubs) > max_hubs:
            errs.append(f"{rid}: has {len(hubs)} hubs > {max_hubs}.")
        pset = {province_map[h] for h in hubs}
        if len(pset) > 1:
            errs.append(f"{rid}: crosses provinces {sorted(pset)}.")

    return errs


def run_planning(
    excel_path: Path,
    output_dir: Path,
    allow_two_soc: bool,
    max_hubs_per_trip: int,
) -> None:
    distance, _time_mins, metadata = load_inputs(excel_path)

    soc_df = metadata[metadata["NodeType"] == "SOC"].copy()
    hubs_df = metadata[metadata["NodeType"] == "HUB"].copy()

    if soc_df.empty or hubs_df.empty:
        raise ValueError("Node_Metadata must contain both SOC and HUB rows.")

    all_assignments = []
    for province, hubs_p in hubs_df.groupby("Province"):
        # Province wall: only hubs in same province are solved together.
        # SOC candidates can be all SOCs; model picks one (or two if allowed).
        assign_p = solve_province_assignment(
            province=province,
            hubs_df=hubs_p,
            soc_df=soc_df,
            distance=distance,
            truck_types=DEFAULT_TRUCK_TYPES,
            max_hubs_per_trip=max_hubs_per_trip,
            allow_two_soc=allow_two_soc,
        )
        all_assignments.append(assign_p)

    assignments = pd.concat(all_assignments, ignore_index=True) if all_assignments else pd.DataFrame()
    routes = pack_to_routes(assignments, max_hubs_per_trip=max_hubs_per_trip)
    route_summary = compute_costs(routes, truck_types=DEFAULT_TRUCK_TYPES)
    violations = validate_business_rules(routes, metadata=metadata, max_hubs=max_hubs_per_trip)

    output_dir.mkdir(parents=True, exist_ok=True)
    detail_path = output_dir / "truck_plan_detail.csv"
    summary_path = output_dir / "truck_plan_summary.csv"
    qa_path = output_dir / "qa_report.json"

    routes.to_csv(detail_path, index=False, encoding="utf-8-sig")
    route_summary.to_csv(summary_path, index=False, encoding="utf-8-sig")
    qa = {
        "num_routes": int(route_summary.shape[0]),
        "total_cost_vnd": float(route_summary["TotalCost_VND"].sum()) if not route_summary.empty else 0.0,
        "violations": violations,
        "assumptions": {
            "truck_types": {k: vars(v) for k, v in DEFAULT_TRUCK_TYPES.items()},
            "max_hubs_per_trip": max_hubs_per_trip,
            "allow_two_soc": allow_two_soc,
            "empty_run_penalty_rule": "50% one-way cost when FM==0 or LM==0",
            "distance_cost_basis": "sum of SOC<->Hub loops (approximate route distance)",
        },
    }
    qa_path.write_text(json.dumps(qa, ensure_ascii=False, indent=2), encoding="utf-8")

    print("Done.")
    print(f"- Detail:  {detail_path}")
    print(f"- Summary: {summary_path}")
    print(f"- QA:      {qa_path}")
    if violations:
        print("Business-rule violations detected:")
        for e in violations:
            print(f"  - {e}")


def build_arg_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="Linehaul truck planning optimizer")
    p.add_argument("--excel", required=True, type=Path, help="Path to input Excel file")
    p.add_argument("--output", required=True, type=Path, help="Output directory")
    p.add_argument(
        "--allow-two-soc",
        default="false",
        choices=["true", "false"],
        help="Allow assignment to up to 2 SOC in one province",
    )
    p.add_argument(
        "--max-hubs-per-trip",
        type=int,
        default=3,
        help="Maximum hubs served per route",
    )
    return p


def main() -> None:
    args = build_arg_parser().parse_args()
    run_planning(
        excel_path=args.excel,
        output_dir=args.output,
        allow_two_soc=_safe_bool(args.allow_two_soc),
        max_hubs_per_trip=args.max_hubs_per_trip,
    )


if __name__ == "__main__":
    main()
